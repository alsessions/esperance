{
    "require": {
        "craftcms/ckeditor": "^3.9.0",
        "craftcms/cms": "^4.5.13",
        "craftcms/contact-form": "^3.0.0",
        "craftcms/feed-me": "^5.3.0",
        "ether/seo": "^4.2",
        "hybridinteractive/craft-contact-form-extensions": "^4.2.2",
        "mmikkel/cp-clearcache": "^1.2",
        "nystudio107/craft-imageoptimize": "^4.0.2",
        "ostark/craft-async-queue": "3.2.1",
        "spicyweb/craft-quick-field": "^2.0",
        "topshelfcraft/wordsmith": "^4.4.0",
        "verbb/expanded-singles": "^2.0",
        "verbb/formie": "2.2.1",
        "vlucas/phpdotenv": "^5.4.0"
    },
    "require-dev": {
        "yiisoft/yii2-shell": "^2.0.3"
    },
    "autoload": {
        "psr-4": {
            "modules\\": "modules/"
        }
    },
    "config": {
        "allow-plugins": {
            "craftcms/plugin-installer": true,
            "yiisoft/yii2-composer": true
        },
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.1.7"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://composer.craftcms.com",
            "canonical": false
        }
    ]
}