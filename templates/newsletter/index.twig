{% extends '_partials/_layout.twig' %}

{% block content %}

<div class="max-w-none">

<h2 class="text-3xl md:text-4xl font-medium text-center">
  The Archive
</h2>
<h3 class="text-xl italic text-center mt-4 mb-16">
  Preserving Esperance's History for Future Generations
</h3>

<div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4 md:gap-10">
{% set newsletters = craft.entries()
    .section('newsletterIssues')
    .limit(10) %}
  
  {# Fetch the entries #}
  {% set entries = newsletters.all() %}

  {% for entry in entries %}
  <div>
    <h2 class="text-xl md:text-2xl mb-2">{{ entry.title }}</h2>
    

    {% set myAsset = entry.newsletterFile.one() %}
{% set optimizedImages = entry.coverImage.one().optimizedNewsCover %}
<a href="{{ myAsset.url }}"><img src="{{ optimizedImages.srcWebp() }}"
                  srcset="{{ optimizedImages.srcset() }}"
                  sizes="100vw"
                  alt="Esperance Museum Newsletter cover"
                  class="border border-gray-400 shadow-sm" />   
</a>          







       

        {% if myAsset %}
            <a href="{{ myAsset.url }}" class=" bg-blue-500 text-white hover:text-white  rounded shadow-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-opacity-75 block py-2 px-4 rounded inline-flex items-center my-4 text-sm">
        
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
          <span>View/Download</span>
          </a>
        {% endif %}
</div>
  
  {% endfor %} 
  </div> 

</div>


{% endblock %}

