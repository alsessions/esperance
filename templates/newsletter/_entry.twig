{% extends '_partials/_layout.twig' %}

{% block content %}

<div class="prose prose-a:no-underline max-w-none">


<h1>{{ entry.title }}</h1>

{% set myAsset = entry.newsletterFile.one() %}

{% if myAsset %}
<a href="{{ myAsset.url }}" class=" bg-blue-500 text-white hover:text-white font-semibold rounded-lg shadow-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-opacity-75 block py-2 px-4 rounded inline-flex items-center">

<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
  <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
</svg>
  <span>View/Download</span>
  </a>
{% endif %}

{% set image = entry.coverImage.one() %}
        {% if image %}
            <img src="{{ image.getUrl('wide640') }}" alt="{{ image.title }}" class="border border-gray-800" />
        {% endif %}

</div>


{% endblock %}

