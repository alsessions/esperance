<!DOCTYPE html>
<html lang="en-US">
<head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta charset="utf-8" />
    <title>Esperance Historical Museum</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <meta name="referrer" content="origin-when-cross-origin" />
    <link href="/css/styles.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,400;0,500;1,300&family=Playfair+Display:wght@400;500;600&family=Work+Sans:wght@300;400;600&display=swap" rel="stylesheet"> 
    <script src="https://cdn.jsdelivr.net/gh/alpinejs/alpine@v2.3.5/dist/alpine.min.js" defer></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lazysizes/5.3.2/lazysizes.min.js" integrity="sha512-q583ppKrCRc7N5O0n2nzUiJ+suUv7Et1JGels4bXOaMFQcamPk9HjdUknZuuFjBNs7tsMuadge5k9RzdmO+1GQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

    <style>
        [x-cloak] {
            visibility: hidden;
            overflow: hidden
        }
    </style>


        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
        <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
        <link rel="manifest" href="/site.webmanifest">
        <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#5bbad5">
        <meta name="msapplication-TileColor" content="#da532c">
        <meta name="theme-color" content="#ffffff">



    <link rel="stylesheet" href="/js/lightgallery/css/lightgallery-bundle.css">
    <link rel="stylesheet" href="/js/lightgallery/css/lg-transitions.css">
    <script src="/js/lightgallery/lightgallery.min.js"></script>
    <script src="/js/lightgallery/plugins/thumbnail/lg-thumbnail.min.js"></script>
    <script src="/js/lightgallery/plugins/thumbnail/lg-zoom.min.js"></script>

    
</head>

<body class="bg-zinc-50">
    {% include '_partials/_nav2.twig' %}      
    <main class="max-w-6xl mx-auto py-20  px-4 min-h-screen">
    {% block content %}
<div class="prose max-w-none">
    <h1>{{ entry.title | widont }}</h1>
    <div class="prose prose-lg">
    {{ entry.text }}
    </div>
<!-- Top Gallery Nav -->
    <div class="not-prose grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mx-auto my-10">
    {% set myEntryQuery = craft.entries()
      .section('photos')
      .level('1')
      .id('not ' ~ entry.id)
      .limit(10) %}

    {% set entries = myEntryQuery.all() %}

    {% for entry in entries %}
        {% set childCount = craft.entries.section('photos').descendantOf(entry.id).count() %}
        {% set photoCount = entry.photos.count() %}
        <div class="relative bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow duration-300 overflow-hidden">
            <div class="p-4">
                <h2 class="mb-2 text-xl md:text-lg font-sans text-blue-600 hover:text-blue-800">
                    <a href="{{ entry.url() }}" class="flex items-center hover:underline">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-blue-600 mr-2 flex-shrink-0">
                            <path d="M19.5 21a3 3 0 003-3v-4.5a3 3 0 00-3-3h-15a3 3 0 00-3 3V18a3 3 0 003 3h15zM1.5 10.146V6a3 3 0 013-3h5.379a2.25 2.25 0 011.59.659l2.122 2.121c.14.141.331.22.53.22H19.5a3 3 0 013 3v1.146A4.483 4.483 0 0019.5 9h-15a4.483 4.483 0 00-3 1.146z" />
                        </svg>
                        <span>{{ entry.title | widont }}</span>
                    </a>
                </h2>
                <div class="text-sm text-gray-600 mt-1 flex items-center">
                    {% if childCount > 0 %}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 mr-1">
                            <path d="M2 4.5A2.5 2.5 0 014.5 2h11a2.5 2.5 0 012.5 2.5v11a2.5 2.5 0 01-2.5 2.5h-11A2.5 2.5 0 012 15.5v-11z" />
                            <path d="M2.75 9.083a.75.75 0 000 1.5h14.5a.75.75 0 000-1.5H2.75z" />
                        </svg>
                        {% if childCount == 1 %}
                            <span>{{ childCount }} gallery</span>
                        {% else %}
                            <span>{{ childCount }} galleries</span>
                        {% endif %}
                    {% else %}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 mr-1">
                            <path fill-rule="evenodd" d="M1 5.25A2.25 2.25 0 013.25 3h13.5A2.25 2.25 0 0119 5.25v9.5A2.25 2.25 0 0116.75 17H3.25A2.25 2.25 0 011 14.75v-9.5zm1.5 5.81v3.69c0 .414.336.75.75.75h13.5a.75.75 0 00.75-.75v-2.69l-2.22-2.219a.75.75 0 00-1.06 0l-1.91 1.909.47.47a.75.75 0 11-1.06 1.06L6.53 8.091a.75.75 0 00-1.06 0l-2.97 2.97zM12 7a1 1 0 11-2 0 1 1 0 012 0z" clip-rule="evenodd" />
                        </svg>
                        {% if photoCount == 1 %}
                            <span>{{ photoCount }} photo</span>
                        {% else %}
                            <span>{{ photoCount }} photos</span>
                        {% endif %}
                    {% endif %}
                </div>
            </div>
        </div>
    {% endfor %}
    </div>
    <!-- End Gallery Nav -->
    
    <!-- Begin Gallery sub-nav -->
    <div class="max-w-none">
        {% if entry.hasDescendants() %}
            <div class="not-prose grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mx-auto my-10">
                {% for entry in craft.entries.section('photos').descendantOf(entry.id).orderBy('title asc').all() %}
                    <div class="relative bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow duration-300 overflow-hidden">
                        <div class="p-4">
                            <h2 class="mb-2 text-lg md:text-base font-sans text-blue-600 hover:text-blue-800">
                                <a href="{{ entry.url }}" class="flex items-center hover:underline">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-blue-600 mr-2 flex-shrink-0">
                                        <path d="M19.5 21a3 3 0 003-3v-4.5a3 3 0 00-3-3h-15a3 3 0 00-3 3V18a3 3 0 003 3h15zM1.5 10.146V6a3 3 0 013-3h5.379a2.25 2.25 0 011.59.659l2.122 2.121c.14.141.331.22.53.22H19.5a3 3 0 013 3v1.146A4.483 4.483 0 0019.5 9h-15a4.483 4.483 0 00-3 1.146z" />
                                    </svg>
                                    <span>{{ entry.title | widont }}</span>
                                </a>
                            </h2>
                            {% set photoCount = entry.photos.count() %}
                            <div class="text-xs text-gray-600 mt-1 flex items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3 mr-1">
                                    <path fill-rule="evenodd" d="M1 5.25A2.25 2.25 0 013.25 3h13.5A2.25 2.25 0 0119 5.25v9.5A2.25 2.25 0 0116.75 17H3.25A2.25 2.25 0 011 14.75v-9.5zm1.5 5.81v3.69c0 .414.336.75.75.75h13.5a.75.75 0 00.75-.75v-2.69l-2.22-2.219a.75.75 0 00-1.06 0l-1.91 1.909.47.47a.75.75 0 11-1.06 1.06L6.53 8.091a.75.75 0 00-1.06 0l-2.97 2.97zM12 7a1 1 0 11-2 0 1 1 0 012 0z" clip-rule="evenodd" />
                                </svg>
                                {% if photoCount == 1 %}
                                    <span>{{ photoCount }} photo</span>
                                {% else %}
                                    <span>{{ photoCount }} photos</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
  <!-- End Gallery sub-nav -->

       <div class="inline-flex items-center my-4 text-sm md:text-base text-gray-600 max-w-7xl mx-auto">
        	
                <svg class="w-5 h-5 inline fill-current mr-2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" d="M1.5 6a2.25 2.25 0 012.25-2.25h16.5A2.25 2.25 0 0122.5 6v12a2.25 2.25 0 01-2.25 2.25H3.75A2.25 2.25 0 011.5 18V6zM3 16.06V18c0 .414.336.75.75.75h16.5A.75.75 0 0021 18v-1.94l-2.69-2.689a1.5 1.5 0 00-2.12 0l-.88.879.97.97a.75.75 0 11-1.06 1.06l-5.16-5.159a1.5 1.5 0 00-2.12 0L3 16.061zm10.125-7.81a1.125 1.125 0 112.25 0 1.125 1.125 0 01-2.25 0z" clip-rule="evenodd" />
                </svg>
    
    <span class="hidden md:inline mr-1 font-sans">Click</span><span class="md:hidden mr-1">Tap</span> for full image</span>
            </div>
   
<div class="grid md:grid-cols-3 lg:grid-cols-4 gap-2 md:gap-10" id="lightgallery" >
        {% for photo in entry.photos.all() %}
      
                <a href="{{ photo.getUrl() }}">
     <picture class="not-prose flex items-center">
         <source data-srcset="{{ photo.optimizedSquare.srcsetWebP() }}" 
                 data-sizes="100vw"
                 type="image/webp" />
                 <img class="lazyload w-full h-auto rounded"
              src="{{ photo.optimizedSquare.placeholderImage() }}"
              data-srcset="{{ photo.optimizedSquare.srcset() }}"
              data-sizes="100vw" />
      </picture>
                </a>
   
        
           {% endfor %}
</div>


</div>

</div>

    {% endblock %}
    <script type="text/javascript">
        lightGallery(document.getElementById("lightgallery"), {
            speed: 500,
            thumbnail: false,
            thumbMargin: 20,
            thumbHeight: 120,
            thumbWidth: 120,
            download: true,
            plugins: [lgThumbnail],
        });
    </script>
    
    </main>
    {% include '_partials/_footer.twig' %}
</body>
</html>