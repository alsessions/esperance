{% include '_partials/_head.twig' %}    

<body class="bg-zinc-50">
    {% include '_partials/_nav2.twig' %}
    <main class="max-w-6xl mx-auto py-20  px-4 min-h-screen">
        <h1 class="text-3xl md:text-5xl text-yellow-900">{{ category.title | widont }}</h1>
        <h2  class="text-xl md:text-2xl text-yellow-800 mt-4">{{ category.description | widont }}</h2>
       <div class="my-4">
        <form action="{{ url('search/results-books') }}">
          <input type="search" name="q" aria-label="Search" placeholder="Search by Title or Author" class="py-1 px-2 rounded my-2">
              <button type="submit" class="border border-1 border-orange-800 bg-orange-900  text-white py-1 px-2 ml-2 rounded">Go</button>
           
          </form>
        </div> 
     
      {% set categories = craft.categories.group('itemType').orderBy('title').all %}
<div class="max-w-6xl mx-auto mb-20 text-sm">

              <div class="grid grid-cols-2 md:grid-cols-3 gap-x-1">
{% for category in categories %}

    <p><a href="{{ category.url }}" class="text-blue-500">{{ category.title }}</a> - {{ category.description }}</p>
  {% endfor %}
              

</div>

</div>
<div class="flex flex-col">
    <div class="overflow-x-auto sm:-mx-6 lg:-mx-8">
      <div class="py-2 inline-block min-w-full sm:px-6 lg:px-8">
        <div class="overflow-hidden">
          <table class="min-w-full">
            <thead class="border-b">
              <tr>
                <th scope="col" class="text-base font-medium text-gray-900 px-6 py-4 text-left">
                  Title
                </th>
                <th scope="col" class="text-base font-medium text-gray-900 px-6 py-4 text-left">
                 Author
                </th>
                <th scope="col" class="text-base font-medium text-gray-900 px-6 py-4 text-left">
                  Date
                </th>
              
                
              </tr>
            </thead>
  
            <tbody>
              {% set query = craft.entries()
                .section('books')
                .relatedTo(category)
                .limit(25)
            %}
              {% paginate query as pageInfo, pageEntries %}         

              {% for entry in pageEntries %}
             

<tr class="border-b">
  <td class="px-6 py-4  text-sm font-medium text-yellow-800"><a
      href="{{ entry.url() }}"><svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 inline-block mr-1 mb-1" viewBox="0 0 20 20" fill="currentColor">
          <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
          <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
        </svg>{{ entry.title }}</a></td>
  <td class="text-sm text-gray-900 font-light px-6 py-4 ">
    {{ entry.bookAuthor }}
  </td>
  <td class="text-sm text-gray-900 font-light px-6 py-4 ">
    {{ entry.date }}
  </td>


</tr>

{% endfor %}
</tbody>

</table>
</div>
</div>
</div>
</div>
<div class="flex flex-wrap items-center justify-center gap-2 my-10">
  <a href="{{ pageInfo.firstUrl }}" class="px-4 py-2 text-gray-700 bg-gray-200 rounded-md hover:bg-blue-400 hover:text-white">First</a>
  {% if pageInfo.prevUrl %}
      <a href="{{ pageInfo.prevUrl }}/#top" class="px-4 py-2 text-gray-700 bg-gray-200 rounded-md hover:bg-blue-400 hover:text-white">Previous</a>
  {% endif %}
  {% for page, url in pageInfo.getPrevUrls(5) %}
      <a href="{{ url }}/#top" class="px-4 py-2 text-gray-700 bg-gray-200 rounded-md hover:bg-blue-400 hover:text-white">{{ page }}</a>
  {% endfor %}
  <span class="px-4 py-2 text-gray-700 bg-gray-200 rounded-md hover:bg-blue-400 hover:text-white">{{ pageInfo.currentPage }}</span>
  {% for page, url in pageInfo.getNextUrls(5) %}
      <a href="{{ url }}/#top" class="px-4 py-2 text-gray-700 bg-gray-200 rounded-md hover:bg-blue-400 hover:text-white">{{ page }}</a>
  {% endfor %}
  {% if pageInfo.nextUrl %}
      <a href="{{ pageInfo.nextUrl }}/#top" class="px-4 py-2 text-gray-700 bg-gray-200 rounded-md hover:bg-blue-400 hover:text-white">Next</a>
  {% endif %}
  <a href="{{ pageInfo.lastUrl }}/#top" class="px-4 py-2 text-gray-700 bg-gray-200 rounded-md hover:bg-blue-400 hover:text-whitep">Last</a>
</div>




</main>
{% include '_partials/_footer.twig' %}



