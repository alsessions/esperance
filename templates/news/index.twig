{% include '_partials/_head.twig' %}

<body class="bg-white">
    {% include '_partials/_nav2.twig' %}
    <div class="my-20 max-w-6xl mx-auto px-4 prose">
        <h1 class="text-3xl md:text-5xl  text-yellow-900 mb-2">News &amp; Events</h1>
        <h3 class="mt-0"><a href="/newsletters"class="no-underline hover:underline-offset-4 hover:underline font-sans">[News Archive]</a></h3>


        <div>

            <h2 class="text-2xl text-yellow-800 tracking-wide">
                Upcoming Events</h2>
            <div class="grid grid-cols-3">
                {# Create an entry query with the 'section' and 'limit' parameters #}
                {% set myEntryQuery = craft.entries()
                .section('exhibits')
                .startDate('>= '~ now|atom)
                .orderBy('startDate asc')
                .limit(10) %}

                {# Fetch the entries #}
                {% set entries = myEntryQuery.all() %}
                    
                {# Display the entries #}
                {% for entry in entries %}
                <article class="not-prose">
                    {% if entry.endDate | length %}
                    <h3 class=" my-2  text-gray-800 font-sans">{{ entry.startDate | date("M d, Y") }}
                        -
                        {{ entry.endDate | date("M d, Y") }}</h3>

                    {% else %}

                    <h3 class="font-sans mt-1  text-gray-800">{{ entry.startDate | date("M d, Y") }}</h3>
                    {% endif %}

                    <h2 class="mt-0 text-lg font-serif  text-yellow-800">
                        <a href="{{ entry.url() }}" class="no-underline">{{ entry.title }}</a>
                    </h2>


                </article>
                {% endfor %}
                <p>Please check back soon.</p>
            </div>
        </div>
    </div>


    <main class="min-h-screen">
        <div class="max-w-6xl mx-auto">
            <h2 class="text-2xl text-yellow-800 tracking-wide px-4 mb-4">
                News from the Museum</h2>
        </div>
        <div class="max-w-6xl mx-auto pb-20 grid md:grid-cols-2 lg:grid-cols-3 gap-6 px-4 rounded">

            {# Create an entry query with the 'section' and 'limit' parameters #}
            {% set myEntryQuery = craft.entries()
            .section('news')
            .limit(10) %}

            {# Fetch the entries #}
            {% set entries = myEntryQuery.all() %}

            {# Display the entries #}
            {% for entry in entries %}
            <article class="bg-gray-50 rounded shadow">


                {% set optimizedImages = entry.newsImage.one().newsImageOptimized %}
                <a href="{{ entry.url() }}">
                    <picture class="">
                        <source data-srcset="{{ optimizedImages.srcsetWebP() }}" data-sizes="100vw" type="image/webp" />
                        <img class="lazyload w-full h-auto rounded-t " src="{{ optimizedImages.placeholderImage() }}"
                            data-srcset="{{ optimizedImages.srcset() }}" data-sizes="100vw" />
                    </picture>
                </a>
                <h3 class="font-sans  text-yellow-900 px-2 mt-2">{{ entry.postDate | date("M d, Y") }}</h3>
                <h2 class="mt-2 text-lg  px-2   text-yellow-800"><a href="{{ entry.url() }}">{{ entry.title | widont
                        }}</a></h2>

                {% if entry.richText | length %}
                <div class="max-w-none  mt-2 pb-4 px-2">
                    {{ entry.richText | chop(limit=15, unit='w', append='...', allowedTags="") | widont }}
                </div>
                {% endif %}
            </article>
            {% endfor %}

        </div>
        <div class="max-w-6xl mx-auto mb-20">
        {% include '_partials/_patrons' %}
        </div>
    </main>
    {% include '_partials/_footer.twig' %}
</body>

</html>