        <div class="">
            <p>
                123 Church St.<br>
                Esperance, NY 12066<br>
                (518) 875-6854<br><br>
            </div>
            <div class="mx-auto">
                <p class="text-center">Open Weekends, Memorial through Labor Days.<br>Admission is Always Free<br>1 to 4 p.m.</p>
                {% if currentUser and entry is defined %}
                    <br><p class="text-center">
                        <a href="{{ entry.cpEditUrl }}">Edit this entry</a>
