{% include '_partials/_head.twig' %}
<body class="bg-zinc-50">
    {% include '_partials/_nav2.twig' %}
    <main class="max-w-6xl mx-auto py-20  px-4 min-h-screen">
        <article>
            <h1 class="text-3xl md:text-5xl  text-yellow-900">{{ entry.title | widont }}</h1>
            <div
                class="max-w-7xl  mx-auto pb-10">
                <!-- Featured matrix field -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mt-10">
                    {% for block in entry.featured.all() %}
                        <script>
                            AOS.init();
                        </script>
                        <div class="flex flex-wrap rounded-lg  shadow-lg hover:saturate-200 mb-20 " data-aos="fade-up" data-aos-duration="500" data-aos-easing="ease-in-out">
                            <div class=" md:w-7/12 pt-2 px-4 ">
                                <h2 class="font-sans text-xl mb-2   inline-block uppercase ">
                                    <a href="{{ block.ctaLink }}">{{ block.featuredItem }}</a>
                                </h2>
                                <div class=" prose">{{ block.description | markdown | typogrify }}</div>
                            </div>
                            <div class="md:w-5/12 order-first md:order-last">
                                {% set optimizedImages = block.featuredImage.one().optimizedSquare %}
                                <picture class="">
                                    <source data-srcset="{{ optimizedImages.srcsetWebP() }}" data-sizes="100vw" type="image/webp"/>
                                    <img class="lazyload w-full h-auto rounded-t " src="{{ optimizedImages.placeholderImage() }}" data-srcset="{{ optimizedImages.srcset() }}" data-sizes="100vw"/>
                                </picture>
                            </a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
        <div  class="prose prose-lg prose-headings:font-normal max-w-none mt-10">
            {{ entry.formattedText }}
        </div>
    </article>
</main>
{% include '_partials/_footer.twig' %}
